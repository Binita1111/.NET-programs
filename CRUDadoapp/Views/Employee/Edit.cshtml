@model CRUDadoapp.Models.Employee

<h2>Edit Employee</h2>

<form method="post">
    <input type="hidden" asp-for="Id" />
    Name: <input asp-for="Name" /><br />
    Gender: <input asp-for="Gender" /><br />
    Age: <input asp-for="Age" /><br />
    Department: <input asp-for="Department" /><br />
    City: <input asp-for="City" /><br />
    <button type="submit">Update</button>
</form>
